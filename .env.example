# Copy to .env and fill in. .env is gitignored and should be chmod 600.
# At deploy time, .env is placed at plugins/PokeMC/.env (or export these as real
# environment variables instead). Precedence: real env var > .env > config.yml.

# Optional: pin the MCP bearer key Poke must present. If unset, one is
# auto-generated and stored (chmod 600) at plugins/PokeMC/mcp-api-key.txt.
# MCP_API_KEY=

# Not needed in the normal (Telegram) setup — wishes go through the Telegram
# chat, not this key. Uncomment only if you know you need it.
# POKE_API_KEY=

# --- Telegram bridge (TDLib user client) — REQUIRED ---
# This is how Poke talks back. PokeMC disables itself if this is off.
TELEGRAM_ENABLED=true
#
# Linking is done from the server console — no restarts, no .env edits:
#   /poke link <+phone>   ->   /poke code <code>   [->  /poke password <pw>]
# TDLib then saves the session on disk, so later restarts auto-link.
#
# App credentials default to PokeMC's bundled Telegram app — override only if you
# want to use your own from https://my.telegram.org.
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
#
# Optional: pre-fill the phone to skip /poke link. Code/password are normally
# entered via the console commands above, not stored here.
# TELEGRAM_PHONE_NUMBER=+15551234567
# TELEGRAM_AUTH_CODE=
# TELEGRAM_AUTH_PASSWORD=
